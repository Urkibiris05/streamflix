# TMDB configuration
TMDB_API_KEY=your_tmdb_api_key_here
TMDB_BASE_URL=https://api.themoviedb.org/3
TMDB_LANGUAGE=es-ES
TMDB_MAX_PAGES=3
TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p/w500

# Sync behavior
MOVIES_PROVIDER_SOURCE=tmdb
MOVIES_PROVIDER_TIMEOUT_SECONDS=8
MOVIES_SYNC_INTERVAL_MINUTES=60
MOVIES_SYNC_MAX_PAGES=2
MOVIES_SYNC_PAGE_LIMIT=50
MOVIES_AUTO_SYNC_ON_READ=true

# Optional fallback providers
OMDB_PROVIDER_URL=https://www.omdbapi.com/
OMDB_API_KEY=thewdb
OMDB_RECENT_YEARS=3
OMDB_MAX_PAGES_PER_QUERY=2
OMDB_MAX_TITLES=120
GHIBLI_PROVIDER_URL=https://ghibliapi.vercel.app/films
